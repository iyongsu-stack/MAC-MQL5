#property copyright "Gemini 3 Agent"
#property version   "1.00"
#include <Trade\Trade.mqh>
#include <Trade\PositionInfo.mqh>
#include <Trade\SymbolInfo.mqh>

input double InpRiskPercent = 2.0;    // Risk Per Trade (%)
input int    InpLookback    = 20;     // Swing High/Low Lookback
input double InpStopBuffer  = 50;     // Stop Loss Buffer (points)
input int    InpMagicNum    = 222222; // Magic Number
input int    InpTrailStart  = 200;    // Trailing Start (points)

CTrade trade;
CPositionInfo pos;
CSymbolInfo sym;

struct SwingPoint {
   double price;
   int    barIndex;
   bool   isHigh;
};

int OnInit() {
   trade.SetExpertMagicNumber(InpMagicNum);
   sym.Name(_Symbol);
   sym.RefreshRates();
   return(INIT_SUCCEEDED);
}

void OnTick() {
   if(!sym.RefreshRates()) return;
   ManageTrailing();
   
   if(pos.Select(_Symbol) && pos.Magic() == InpMagicNum) return; // Only 1 trade

   // Logic: 
   // 1. Identify recent Swing High/Low broken by price
   // 2. Identify "Breaker" (The candle that created the level)
   // 3. Entry on retest of that level
   
   // Simplified for EA: 
   // Buy if Price broke a Swing High, then comes back down to touch it.
   // Sell if Price broke a Swing Low, then comes back up to touch it.
   
   double swingHigh = GetHighestSwing(InpLookback);
   double swingLow  = GetLowestSwing(InpLookback);
   
   double close1 = iClose(_Symbol, PERIOD_CURRENT, 1);
   double low1   = iLow(_Symbol, PERIOD_CURRENT, 1);
   double high1  = iHigh(_Symbol, PERIOD_CURRENT, 1);
   
   // Breaker Buy Logic
   static bool brokenHigh = false;
   static double brokenHighLevel = 0;
   
   if(!brokenHigh && close1 > swingHigh) {
      brokenHigh = true;
      brokenHighLevel = swingHigh;
   }
   
   // If broken, wait for retest
   if(brokenHigh) {
      if(low1 <= brokenHighLevel && close1 > brokenHighLevel) { // Touch and reject
          OpenTrade(ORDER_TYPE_BUY, brokenHighLevel - InpStopBuffer*_Point);
          brokenHigh = false; // Reset
      }
      // Reset if price falls too far below
      if(close1 < brokenHighLevel - 200*_Point) brokenHigh = false;
   }
   
   // Breaker Sell Logic (Similar Mirror)
   static bool brokenLow = false;
   static double brokenLowLevel = 0;
   
   if(!brokenLow && close1 < swingLow) {
      brokenLow = true;
      brokenLowLevel = swingLow;
   }
   
   if(brokenLow) {
      if(high1 >= brokenLowLevel && close1 < brokenLowLevel) {
          OpenTrade(ORDER_TYPE_SELL, brokenLowLevel + InpStopBuffer*_Point);
          brokenLow = false;
      }
      if(close1 > brokenLowLevel + 200*_Point) brokenLow = false;
   }
}

double GetHighestSwing(int count) {
   int highest = iHighest(_Symbol, PERIOD_CURRENT, MODE_HIGH, count, 2);
   return iHigh(_Symbol, PERIOD_CURRENT, highest);
}

double GetLowestSwing(int count) {
   int lowest = iLowest(_Symbol, PERIOD_CURRENT, MODE_LOW, count, 2);
   return iLow(_Symbol, PERIOD_CURRENT, lowest);
}

void OpenTrade(ENUM_ORDER_TYPE type, double slPrice) {
   double price = (type == ORDER_TYPE_BUY) ? sym.Ask() : sym.Bid();
   double sl = slPrice;
   double tp = (type == ORDER_TYPE_BUY) ? price + (price-sl)*2 : price - (sl-price)*2; // RR 1:2
   
   // Calc Lot
   double bal = AccountInfoDouble(ACCOUNT_BALANCE);
   double risk = bal * (InpRiskPercent/100.0);
   double dist = MathAbs(price - sl);
   double tickVal = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_VALUE);
   double lot = NormalizeDouble(risk / (dist/_Point * tickVal), 2);
   if(lot < 0.01) lot = 0.01;
   
   trade.PositionOpen(_Symbol, type, lot, price, sl, tp, "Mitigation Block");
}

void ManageTrailing() {
    if(InpTrailStart <= 0) return;
    for(int i=PositionsTotal()-1; i>=0; i--) {
        if(pos.SelectByIndex(i) && pos.Magic() == InpMagicNum) {
            double current = (pos.PositionType()==POSITION_TYPE_BUY) ? sym.Bid() : sym.Ask();
            double open = pos.PriceOpen();
            double sl = pos.StopLoss();
            
            if(MathAbs(current - open)/_Point > InpTrailStart) {
                double newSL = (pos.PositionType()==POSITION_TYPE_BUY) ? current - 50*_Point : current + 50*_Point;
                if(pos.PositionType()==POSITION_TYPE_BUY && newSL > sl) trade.PositionModify(_Symbol, newSL, pos.TakeProfit());
                else if(pos.PositionType()==POSITION_TYPE_SELL && (newSL < sl || sl==0)) trade.PositionModify(_Symbol, newSL, pos.TakeProfit());
            }
        }
    }
}

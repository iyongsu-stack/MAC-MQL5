#property copyright "Gemini 3 Agent"
#property version   "2.00"
#property description "Institutional Strategy: Asian Session Liquidity Raid"

//--- Includes
#include <Trade\Trade.mqh>
#include <Trade\SymbolInfo.mqh>
#include <Trade\PositionInfo.mqh>

//--- Input Parameters
input group             "Time Settings"
input int               InpAsianStart  = 0;      // Asian Session Start Hour
input int               InpAsianEnd    = 7;      // Asian Session End Hour (London Pre-Open)
input int               InpTradeEnd    = 19;     // Stop looking for setups after this hour (Full London + NY Open)

input group             "Strategy Logic"
input double            InpSweepMin    = 20;     // Min Sweep Points (2 Pips - Aggressive)
input double            InpSweepMax    = 500;    // Max Sweep Points (50 Pips)
input ENUM_TIMEFRAMES   InpConfirmTF   = PERIOD_M15;
input int               InpTrendPeriod = 30;     // Trend Filter EMA (Fast)
input int               InpRsiPeriod   = 14;     // RSI Period
input double            InpRsiOversold = 35;     // RSI Oversold Level (Buy - Easier)
input double            InpRsiOverbought= 65;    // RSI Overbought Level (Sell - Easier)

input group             "Risk Management"
input double            InpRiskPercent = 2.0;    // Risk per trade (%) - Optimized for growth
input double            InpMaxSpread   = 30;     // Max Spread (Points)
input double            InpTrailingStart= 150;   // Trailing Start (15 Pips - Quick Lock)
input int               InpMagicNum    = 123456; // Magic Number

//--- Global Objects
CTrade         trade;
CSymbolInfo    symbolInfo;
CPositionInfo  positionInfo;

//--- Global Variables
double AsianHigh = -1;
double AsianLow  = -1;
bool   BoxCalculated = false;
int    LastTradeDay = 0;

//+------------------------------------------------------------------+
//| Expert initialization function                                   |
//+------------------------------------------------------------------+
int OnInit()
  {
   if(!symbolInfo.Name(_Symbol)) return(INIT_FAILED);
   symbolInfo.RefreshRates();
   
   trade.SetExpertMagicNumber(InpMagicNum);
   
   Print("Asian Liquidity Sweep Pro [Initialized]");
   return(INIT_SUCCEEDED);
  }

//+------------------------------------------------------------------+
//| Expert tick function                                             |
//+------------------------------------------------------------------+
void OnTick()
  {
   // 1. Time & New Bar Check
   MqlDateTime dt;
   TimeCurrent(dt);
   
   // Robust New Day Check (Fix for backtest issue)
   static int last_day_of_year = -1;
   
   if(last_day_of_year != dt.day_of_year) {
      BoxCalculated = false;
      AsianHigh = -1; 
      AsianLow  = -1;
      // Print("New Day Detected: ", dt.month, "/", dt.day, " Resetting Box"); // Debug
      last_day_of_year = dt.day_of_year;
   }
   
   // 2. Logic: Calculate Box (Only once per day)
   if(!BoxCalculated && dt.hour >= InpAsianEnd) {
      CalculateAsianBox();
      BoxCalculated = true; // Mark as done even if it failed (to avoid retry every tick), retry next day
   }
   
   // Pre-checks
   if(AsianHigh == -1 || AsianLow == -1) return; // Box calculation failed or not ready
   if(!BoxCalculated) return; // Wait for session end
   if(dt.hour >= InpTradeEnd) return; // Too late
   if(IsNewBar() == false) return; // Run logic on new bar open for stability

   // 3. Trading Logic: Check for Sweep
   symbolInfo.RefreshRates();
   CheckTrailingStop(); // Manage existing positions
   
   // Indicators
   double emaVal = 0;
   double rsiVal = 50;
   
   // EMA Filter
   if(InpTrendPeriod > 0) {
      int hEMA = iMA(_Symbol, InpConfirmTF, InpTrendPeriod, 0, MODE_EMA, PRICE_CLOSE);
      double buf[];
      if(CopyBuffer(hEMA, 0, 0, 1, buf)>0) emaVal = buf[0];
      IndicatorRelease(hEMA);
   }
   
   // RSI Filter
   int hRSI = iRSI(_Symbol, InpConfirmTF, InpRsiPeriod, PRICE_CLOSE);
   double rsiBuf[];
   if(CopyBuffer(hRSI, 0, 0, 1, rsiBuf)>0) rsiVal = rsiBuf[0];
   IndicatorRelease(hRSI);

   // Buy Scenario: Sweep Low + Close Back Inside
   double low1 = iLow(_Symbol, InpConfirmTF, 1);
   double close1 = iClose(_Symbol, InpConfirmTF, 1);
   double open1  = iOpen(_Symbol, InpConfirmTF, 1);
   
   // Check if we already have a position
   if(positionInfo.Select(_Symbol) && positionInfo.Magic() == InpMagicNum) return;

   // Simple Sweep Logic: Low was below AsianLow, but Close is above AsianLow
   if(low1 < AsianLow && close1 > AsianLow) {
      // LOGIC UPGRADE:
      // 1. Trend Follow: Price > EMA (Buy Dips)
      // 2. Reversal: RSI < Oversold (Catch Bottoms)
      bool isTrendBuy = (InpTrendPeriod > 0 && close1 > emaVal);
      bool isRsiBuy   = (rsiVal < InpRsiOversold);
      
      if(!isTrendBuy && !isRsiBuy) return; // Skip if neither condition is met
      
      // Candle Strength Check: Close must be higher than Open (Green Candle) working as confirmation
      if(close1 <= open1) return;

      double sweepSize = AsianLow - low1; 
      double sweepPoints = sweepSize / _Point;

      if(sweepPoints >= InpSweepMin && sweepPoints <= InpSweepMax) {
         if(LastTradeDay != dt.day) {
            OpenTrade(ORDER_TYPE_BUY);
            LastTradeDay = dt.day;
         }
      }
   }
   
   // Sell Scenario: Sweep High + Close Back Inside
   double high1 = iHigh(_Symbol, InpConfirmTF, 1);
   // double close1 = iClose(_Symbol, InpConfirmTF, 1); // Removed: already defined
   
   if(high1 > AsianHigh && close1 < AsianHigh) {
       // LOGIC UPGRADE:
      bool isTrendSell = (InpTrendPeriod > 0 && close1 < emaVal);
      bool isRsiSell   = (rsiVal > InpRsiOverbought);
      
      if(!isTrendSell && !isRsiSell) return;

      // Candle Strength Check: Red Candle
      if(close1 >= open1) return;
      
      double sweepSize = high1 - AsianHigh;
      double sweepPoints = sweepSize / _Point;
      
      if(sweepPoints >= InpSweepMin && sweepPoints <= InpSweepMax) {
         if(LastTradeDay != dt.day) {
            OpenTrade(ORDER_TYPE_SELL);
            LastTradeDay = dt.day;
         }
      }
   }
  }

//+------------------------------------------------------------------+
//| Helper: Trailing Stop                                            |
//+------------------------------------------------------------------+
void CheckTrailingStop() {
   if(InpTrailingStart <= 0) return;
   
   for(int i=PositionsTotal()-1; i>=0; i--) {
      if(positionInfo.SelectByIndex(i)) {
         if(positionInfo.Magic() == InpMagicNum && positionInfo.Symbol() == _Symbol) {
             double sl = positionInfo.StopLoss();
             double open = positionInfo.PriceOpen();
             double current = (positionInfo.PositionType() == POSITION_TYPE_BUY) ? symbolInfo.Bid() : symbolInfo.Ask();
             double profitPoints = MathAbs(current - open) / _Point;
             
             if(profitPoints > InpTrailingStart) {
                double newSL = 0;
                if(positionInfo.PositionType() == POSITION_TYPE_BUY) {
                   newSL = current - (InpTrailingStart * _Point);
                   if(newSL > sl) trade.PositionModify(_Symbol, newSL, positionInfo.TakeProfit());
                } else {
                   newSL = current + (InpTrailingStart * _Point);
                   if(newSL < sl || sl == 0) trade.PositionModify(_Symbol, newSL, positionInfo.TakeProfit());
                }
             }
         }
      }
   }
}

//+------------------------------------------------------------------+
//| Helper: Calculate Asian Range High/Low                           |
//+------------------------------------------------------------------+
void CalculateAsianBox() {
   // Calculation logic needs accurate time shifts. 
   // For robust MQL5, we scan the bars between StartHour and EndHour of current day.
   
   MqlDateTime dt;
   TimeCurrent(dt);
   
   // Construct start and end times for the Asian session of "Today"
   datetime todayStart = TimeCurrent() - (TimeCurrent() % 86400); // 00:00 today
   datetime sessionStart = todayStart + (InpAsianStart * 3600);
   datetime sessionEnd   = todayStart + (InpAsianEnd * 3600);
   
   int startIdx = iBarShift(_Symbol, PERIOD_H1, sessionStart);
   int endIdx   = iBarShift(_Symbol, PERIOD_H1, sessionEnd);
   
   if(startIdx == -1 || endIdx == -1) {
      Print("Error: H1 Data missing for Asian Box. Date: ", dt.year, ".", dt.mon, ".", dt.day);
      return;
   }
   
   double maxH = -1.0;
   double minL = 999999.0;
   
   // Loop from End (Right) to Start (Left)? Order doesn't matter for MinMax
   for(int i = endIdx; i <= startIdx; i++) {
      double h = iHigh(_Symbol, PERIOD_H1, i);
      double l = iLow(_Symbol, PERIOD_H1, i);
      if(h > maxH) maxH = h;
      if(l < minL) minL = l;
   }
   
   AsianHigh = maxH;
   AsianLow  = minL;
   
   PrintFormat("Asian Box Calculated: High=%.2f, Low=%.2f", AsianHigh, AsianLow);
}

//+------------------------------------------------------------------+
//| Open Trade with Dynamic Risk                                     |
//+------------------------------------------------------------------+
void OpenTrade(ENUM_ORDER_TYPE type) {
   double sl = 0, tp = 0, openPrice = 0;
   symbolInfo.RefreshRates();
   
   if(type == ORDER_TYPE_BUY) {
      openPrice = symbolInfo.Ask();
      sl = AsianLow - 50 * _Point; // Safety buffer
      tp = AsianHigh;              // Target opposite liquidity
   } else {
      openPrice = symbolInfo.Bid();
      sl = AsianHigh + 50 * _Point;
      tp = AsianLow;
   }
   
   // Validate Stop Loss Distance
   if(MathAbs(openPrice - sl) < symbolInfo.StopsLevel() * _Point) {
       Print("Stop Loss too close");
       return;
   }
   
   // Calculate Lot
   double balance = AccountInfoDouble(ACCOUNT_BALANCE);
   double riskMoney = balance * (InpRiskPercent / 100.0);
   double slDist = MathAbs(openPrice - sl);
   double tickValue = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_VALUE);
   double lot = 0.01;
   
   if(slDist > 0 && tickValue > 0) {
       lot = NormalizeDouble(riskMoney / (slDist / _Point * tickValue), 2);
   }
   
   // Min/Max Lot Check
   double minLot = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MIN);
   double maxLot = SymbolInfoDouble(_Symbol, SYMBOL_VOLUME_MAX);
   if(lot < minLot) lot = minLot;
   if(lot > maxLot) lot = maxLot;
   
   trade.PositionOpen(_Symbol, type, lot, openPrice, sl, tp, "AL-Sweep V2");
}

//+------------------------------------------------------------------+
//| Helper: New Bar Check                                            |
//+------------------------------------------------------------------+
bool IsNewBar() {
   static datetime last_time = 0;
   datetime current_time = iTime(_Symbol, InpConfirmTF, 0);
   if(last_time != current_time) {
      last_time = current_time;
      return true;
   }
   return false;
}
//+------------------------------------------------------------------+

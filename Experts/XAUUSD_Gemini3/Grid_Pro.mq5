//+------------------------------------------------------------------+
#property copyright "Gemini 3 Agent"
#property version   "1.00"
#include <Trade\Trade.mqh>
#include <Trade\PositionInfo.mqh>

input double InpInitialLot  = 0.01;
input int    InpGridStep    = 200; // 20 Pips
input int    InpMaxOrders   = 5;
input int    InpMagicNum    = 101010;

CTrade trade;
CPositionInfo pos;

int OnInit() {
   trade.SetExpertMagicNumber(InpMagicNum);
   return(INIT_SUCCEEDED);
}

void OnTick() {
   // Simple Logic: Always be in market. If no orders, Buy.
   // If price drops X pips, Buy again.
   // Close all on total profit.
   
   int buyCount = 0;
   double totalProfit = 0;
   double lastBuyPrice = 0;
   
   for(int i=PositionsTotal()-1; i>=0; i--) {
       if(pos.SelectByIndex(i) && pos.Magic() == InpMagicNum) {
           totalProfit += pos.Profit();
           if(pos.PositionType() == POSITION_TYPE_BUY) {
               buyCount++;
               if(pos.PriceOpen() < lastBuyPrice || lastBuyPrice == 0) lastBuyPrice = pos.PriceOpen();
           }
       }
   }
   
   // 1. Initial Entry
   if(buyCount == 0) {
       trade.PositionOpen(_Symbol, ORDER_TYPE_BUY, InpInitialLot, SymbolInfoDouble(_Symbol, SYMBOL_ASK), 0, 0, "Grid Start");
       return;
   }
   
   // 2. Add Grid
   double currentAsk = SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   if(buyCount < InpMaxOrders && currentAsk < lastBuyPrice - InpGridStep*_Point) {
       trade.PositionOpen(_Symbol, ORDER_TYPE_BUY, InpInitialLot, currentAsk, 0, 0, "Grid Add");
   }
   
   // 3. Close All on Profit
   if(totalProfit > InpInitialLot * 100 * _Point * buyCount * 10) { // Approx target
       CloseAll();
   }
}

void CloseAll() {
    for(int i=PositionsTotal()-1; i>=0; i--) {
       if(pos.SelectByIndex(i) && pos.Magic() == InpMagicNum) {
           trade.PositionClose(pos.Ticket());
       }
    }
}

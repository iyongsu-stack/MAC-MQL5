//|                                        NewsFade_Pro.mq5          |
//|                             Generated by Gemini 3 (High Quality) |
//+------------------------------------------------------------------+
#property copyright "Gemini 3 Agent"
#property version   "1.00"
#include <Trade\Trade.mqh>
#include <Trade\PositionInfo.mqh>

input double InpRiskPercent = 2.0;
input double InpSpikeSize   = 500; // 50 Pips Spike to trigger
input int    InpMagicNum    = 888888;

CTrade trade;
CPositionInfo pos;

int OnInit() {
   trade.SetExpertMagicNumber(InpMagicNum);
   return(INIT_SUCCEEDED);
}

void OnTick() {
   if(pos.Select(_Symbol) && pos.Magic() == InpMagicNum) return;
   
   double close = iClose(_Symbol, PERIOD_CURRENT, 0);
   double open  = iOpen(_Symbol, PERIOD_CURRENT, 0);
   double size  = MathAbs(close - open) / _Point;
   
   // Logic: If current candle moved HUGE distance rapidly, fade it.
   // Sell if huge green candle
   if(size > InpSpikeSize && close > open) {
       OpenTrade(ORDER_TYPE_SELL);
   }
   
   // Buy if huge red candle
   if(size > InpSpikeSize && close < open) {
       OpenTrade(ORDER_TYPE_BUY);
   }
}

void OpenTrade(ENUM_ORDER_TYPE type) {
   double price = (type == ORDER_TYPE_BUY) ? SymbolInfoDouble(_Symbol, SYMBOL_ASK) : SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double sl = (type == ORDER_TYPE_BUY) ? price - 300*_Point : price + 300*_Point;
   double tp = (type == ORDER_TYPE_BUY) ? price + 300*_Point : price - 300*_Point; // Scalp reverb
   
   double bal = AccountInfoDouble(ACCOUNT_BALANCE);
   double dist = MathAbs(price - sl);
   double lot = NormalizeDouble((bal * InpRiskPercent / 100.0) / (dist / _Point * 1.0), 2); 
   if(lot < 0.01) lot = 0.01;
   
   trade.PositionOpen(_Symbol, type, lot, price, sl, tp, "News Fade");
}

#property copyright "Gemini 3 Agent"
#property version   "1.00"
#include <Trade\Trade.mqh>
#include <Trade\PositionInfo.mqh>

input double InpRiskPercent = 2.0;
input double InpVolMult     = 2.0; // Volume > 2x Average
input int    InpMagicNum    = 999999;

CTrade trade;
CPositionInfo pos;

int OnInit() {
   trade.SetExpertMagicNumber(InpMagicNum);
   return(INIT_SUCCEEDED);
}

void OnTick() {
   if(pos.Select(_Symbol) && pos.Magic() == InpMagicNum) return;
   
   long vol = iTickVolume(_Symbol, PERIOD_CURRENT, 1);
   double avgVol = 0;
   for(int i=2; i<=21; i++) avgVol += iTickVolume(_Symbol, PERIOD_CURRENT, i);
   avgVol /= 20.0;
   
   if(vol < avgVol * InpVolMult) return; // Not high volume
   
   // VSA Logic: Ultra High Volume + Small Body = Stopping Volume / Reversal
   double open = iOpen(_Symbol, PERIOD_CURRENT, 1);
   double close= iClose(_Symbol, PERIOD_CURRENT, 1);
   double high = iHigh(_Symbol, PERIOD_CURRENT, 1);
   double low  = iLow(_Symbol, PERIOD_CURRENT, 1);
   
   double body = MathAbs(close - open);
   double range = high - low;
   
   bool smallBody = (body < range * 0.3); // Body is less than 30% of range (Doji/Pinbar)
   
   if(smallBody) {
       // Pinbar check
       // Long lower wick -> Buy
       if(MathMin(open, close) - low > range * 0.5) {
           OpenTrade(ORDER_TYPE_BUY, low);
       }
       // Long upper wick -> Sell
       else if(high - MathMax(open, close) > range * 0.5) {
           OpenTrade(ORDER_TYPE_SELL, high);
       }
   }
}

void OpenTrade(ENUM_ORDER_TYPE type, double slPrice) {
   double price = (type == ORDER_TYPE_BUY) ? SymbolInfoDouble(_Symbol, SYMBOL_ASK) : SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double sl = slPrice;
   double dist = MathAbs(price - sl);
   if(dist == 0) dist = 100*_Point;
   double tp = (type == ORDER_TYPE_BUY) ? price + dist*2.0 : price - dist*2.0; 
   
   double bal = AccountInfoDouble(ACCOUNT_BALANCE);
   double lot = NormalizeDouble((bal * InpRiskPercent / 100.0) / (dist / _Point * 1.0), 2); 
   if(lot < 0.01) lot = 0.01;
   
   trade.PositionOpen(_Symbol, type, lot, price, sl, tp, "VSA Scalp");
}

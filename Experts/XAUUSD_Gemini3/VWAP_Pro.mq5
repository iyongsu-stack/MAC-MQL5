#property copyright "Gemini 3 Agent"
#property version   "1.00"
#include <Trade\Trade.mqh>
#include <Trade\PositionInfo.mqh>

input double InpRiskPercent = 2.0;
input int    InpMagicNum    = 666666;

CTrade trade;
CPositionInfo pos;

int OnInit() {
   trade.SetExpertMagicNumber(InpMagicNum);
   return(INIT_SUCCEEDED);
}

double CalculateVWAP() {
   // Simple Daily VWAP Calculation
   MqlDateTime dt;
   TimeCurrent(dt);
   datetime startOfDay = TimeCurrent() - (dt.hour*3600 + dt.min*60 + dt.sec);
   
   int startBar = iBarShift(_Symbol, PERIOD_BM15, startOfDay); // PERIOD_M15 base
   if(startBar == -1) return 0;
   
   double sumPV = 0;
   double sumVol = 0;
   
   for(int i=0; i<=startBar; i++) {
       double price = iClose(_Symbol, PERIOD_M15, i); // Typical price (H+L+C)/3 is better usually, using Close for speed
       long vol = iTickVolume(_Symbol, PERIOD_M15, i);
       sumPV += price * vol;
       sumVol += vol;
   }
   
   if(sumVol == 0) return 0;
   return sumPV / sumVol;
}

void OnTick() {
   if(pos.Select(_Symbol) && pos.Magic() == InpMagicNum) return;
   
   double vwap = CalculateVWAP();
   if(vwap == 0) return;
   
   double close = iClose(_Symbol, PERIOD_CURRENT, 0);
   double open  = iOpen(_Symbol, PERIOD_CURRENT, 0);
   
   // Logic: Buy if Price crosses ABOVE VWAP
   if(open < vwap && close > vwap) {
       OpenTrade(ORDER_TYPE_BUY, close - 300*_Point); 
   }
   
   // Logic: Sell if Price crosses BELOW VWAP
   if(open > vwap && close < vwap) {
       OpenTrade(ORDER_TYPE_SELL, close + 300*_Point);
   }
}

void OpenTrade(ENUM_ORDER_TYPE type, double sl) {
   double price = (type == ORDER_TYPE_BUY) ? SymbolInfoDouble(_Symbol, SYMBOL_ASK) : SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double dist = MathAbs(price - sl);
   double tp = (type == ORDER_TYPE_BUY) ? price + dist*2.0 : price - dist*2.0; 
   
   double bal = AccountInfoDouble(ACCOUNT_BALANCE);
   double lot = NormalizeDouble((bal * InpRiskPercent / 100.0) / (dist / _Point * 1.0), 2); 
   if(lot < 0.01) lot = 0.01;
   
   trade.PositionOpen(_Symbol, type, lot, price, sl, tp, "VWAP Trend");
}

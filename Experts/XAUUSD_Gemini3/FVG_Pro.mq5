#property copyright "Gemini 3 Agent"
#property version   "1.00"
#include <Trade\Trade.mqh>
#include <Trade\PositionInfo.mqh>
#include <Trade\SymbolInfo.mqh>

input double InpRiskPercent = 2.0;
input double InpFvgMinPoints= 50;  // Min Gap Size
input int    InpMagicNum    = 333333;
input double InpTpRatio     = 2.0;

CTrade trade;
CPositionInfo pos;
CSymbolInfo sym;

int OnInit() {
   trade.SetExpertMagicNumber(InpMagicNum);
   sym.Name(_Symbol);
   sym.RefreshRates();
   return(INIT_SUCCEEDED);
}

void OnTick() {
   sym.RefreshRates();
   if(pos.Select(_Symbol) && pos.Magic() == InpMagicNum) return;

   // Logic: Detect FVG in previous candles
   // Bullish FVG: Candle[1] High < Candle[3] Low ? (Standard indexing: 0=current, 1=last closed)
   // Standard FVG is a 3-candle pattern.
   // Let's look at bars 1, 2, 3.
   // Gap is between High of Bar 3 and Low of Bar 1 (for Buy).
   
   double high3 = iHigh(_Symbol, PERIOD_CURRENT, 3);
   double low1  = iLow(_Symbol, PERIOD_CURRENT, 1);
   
   // Bullish FVG Detected
   if(low1 > high3 + InpFvgMinPoints*_Point) {
      // Check if price (Bar 0) dips into this gap
      double bid = sym.Bid();
      if(bid < low1 && bid > high3) {
         OpenTrade(ORDER_TYPE_BUY, high3 - 50*_Point); // SL below the gap
      }
   }
   
   // Bearish FVG
   // Gap between Low of Bar 3 and High of Bar 1
   double low3  = iLow(_Symbol, PERIOD_CURRENT, 3);
   double high1 = iHigh(_Symbol, PERIOD_CURRENT, 1);
   
   if(high1 < low3 - InpFvgMinPoints*_Point) {
      double ask = sym.Ask();
      if(ask > high1 && ask < low3) {
         OpenTrade(ORDER_TYPE_SELL, low3 + 50*_Point); // SL above gap
      }
   }
}

void OpenTrade(ENUM_ORDER_TYPE type, double slPrice) {
   double price = (type == ORDER_TYPE_BUY) ? sym.Ask() : sym.Bid();
   double sl = slPrice;
   double dist = MathAbs(price - sl);
   if(dist == 0) return;
   
   double tp = (type == ORDER_TYPE_BUY) ? price + dist*InpTpRatio : price - dist*InpTpRatio;
   
   double bal = AccountInfoDouble(ACCOUNT_BALANCE);
   double risk = bal * (InpRiskPercent/100.0);
   double tickVal = SymbolInfoDouble(_Symbol, SYMBOL_TRADE_TICK_VALUE);
   double lot = NormalizeDouble(risk / (dist/_Point * tickVal), 2);
   if(lot < 0.01) lot = 0.01;
   
   trade.PositionOpen(_Symbol, type, lot, price, sl, tp, "FVG Entry");
}

//+------------------------------------------------------------------+
#property copyright "Gemini 3 Agent"
#property version   "1.00"
#include <Trade\Trade.mqh>
#include <Trade\PositionInfo.mqh>

input double InpRiskPercent = 2.0;
input int    InpBandsPeriod = 20;
input double InpDeviation   = 2.2;
input int    InpRsiPeriod   = 7;
input int    InpMagicNum    = 444444;

CTrade trade;
CPositionInfo pos;

int HandleBands, HandleRSI;

int OnInit() {
   trade.SetExpertMagicNumber(InpMagicNum);
   HandleBands = iBands(_Symbol, PERIOD_CURRENT, InpBandsPeriod, 0, InpDeviation, PRICE_CLOSE);
   HandleRSI   = iRSI(_Symbol, PERIOD_CURRENT, InpRsiPeriod, PRICE_CLOSE);
   return(INIT_SUCCEEDED);
}

void OnTick() {
   if(pos.Select(_Symbol) && pos.Magic() == InpMagicNum) return;

   double upper[], lower[], rsi[];
   CopyBuffer(HandleBands, 1, 1, 1, upper); // Upper Band
   CopyBuffer(HandleBands, 2, 1, 1, lower); // Lower Band
   CopyBuffer(HandleRSI, 0, 1, 1, rsi);
   
   double close1 = iClose(_Symbol, PERIOD_CURRENT, 1);
   
   // Mean Reversion Sell: Price > Upper Band AND RSI > 70
   if(close1 > upper[0] && rsi[0] > 70) {
      OpenTrade(ORDER_TYPE_SELL, upper[0] + 500*_Point); // Wide SL for Mean Rev
   }
   
   // Mean Reversion Buy: Price < Lower Band AND RSI < 30
   if(close1 < lower[0] && rsi[0] < 30) {
      OpenTrade(ORDER_TYPE_BUY, lower[0] - 500*_Point);
   }
}

void OpenTrade(ENUM_ORDER_TYPE type, double sl) {
   double price = (type == ORDER_TYPE_BUY) ? SymbolInfoDouble(_Symbol, SYMBOL_ASK) : SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double dist = MathAbs(price - sl);
   double tp = (type == ORDER_TYPE_BUY) ? price + dist*1.5 : price - dist*1.5;
   
   double bal = AccountInfoDouble(ACCOUNT_BALANCE);
   double lot = NormalizeDouble((bal * InpRiskPercent / 100.0) / (dist / _Point * 1.0), 2); 
   if(lot < 0.01) lot = 0.01;
   
   trade.PositionOpen(_Symbol, type, lot, price, sl, tp, "StatArb V1");
}

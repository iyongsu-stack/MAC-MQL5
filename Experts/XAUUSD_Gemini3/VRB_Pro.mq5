#property copyright "Gemini 3 Agent"
#property version   "1.00"
#include <Trade\Trade.mqh>
#include <Trade\PositionInfo.mqh>

input double InpRiskPercent = 2.0;
input int    InpBBPeriod    = 20;
input double InpDev         = 2.0;
input double InpSqueezeThresh = 0.0010; // Bandwidth threshold
input int    InpMagicNum    = 555555;

CTrade trade;
CPositionInfo pos;
int HandleBB;

int OnInit() {
   trade.SetExpertMagicNumber(InpMagicNum);
   HandleBB = iBands(_Symbol, PERIOD_CURRENT, InpBBPeriod, 0, InpDev, PRICE_CLOSE);
   return(INIT_SUCCEEDED);
}

void OnTick() {
   if(pos.Select(_Symbol) && pos.Magic() == InpMagicNum) return;

   double upper[], lower[], mid[];
   CopyBuffer(HandleBB, 1, 0, 2, upper);
   CopyBuffer(HandleBB, 2, 0, 2, lower);
   
   // Calculate Bandwidth (Upper - Lower) / Middle
   double width0 = (upper[0] - lower[0]);
   double width1 = (upper[1] - lower[1]);
   
   // Squeeze Logic: If width is very small, we are in squeeze. 
   // Breakout: Price closes outside bands AFTER a squeeze.
   
   bool wasSqueeze = (width1 < _Point * 200); // e.g., 20 pips squeeze (very tight for Gold)
   
   double close0 = iClose(_Symbol, PERIOD_CURRENT, 0);
   
   if(wasSqueeze) {
      if(close0 > upper[0]) {
         OpenTrade(ORDER_TYPE_BUY, lower[0]);
      } else if(close0 < lower[0]) {
         OpenTrade(ORDER_TYPE_SELL, upper[0]);
      }
   }
}

void OpenTrade(ENUM_ORDER_TYPE type, double sl) {
   double price = (type == ORDER_TYPE_BUY) ? SymbolInfoDouble(_Symbol, SYMBOL_ASK) : SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double dist = MathAbs(price - sl);
   if(dist < 100*_Point) dist = 100*_Point; // Min SL
   
   double tp = (type == ORDER_TYPE_BUY) ? price + dist*3.0 : price - dist*3.0; // Breakouts run far
   
   double bal = AccountInfoDouble(ACCOUNT_BALANCE);
   double lot = NormalizeDouble((bal * InpRiskPercent / 100.0) / (dist / _Point * 1.0), 2); 
   if(lot < 0.01) lot = 0.01;
   
   trade.PositionOpen(_Symbol, type, lot, price, sl, tp, "VRB Breakout");
}

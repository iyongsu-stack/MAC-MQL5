#property copyright "Gemini 3 Agent"
#property version   "1.00"
#include <Trade\Trade.mqh>
#include <Trade\PositionInfo.mqh>

input double InpRiskPercent = 2.0;
input string InpCorrSymbol  = "USDJPY"; // Proxy for Yields
input int    InpMagicNum    = 777777;

CTrade trade;
CPositionInfo pos;

int OnInit() {
   trade.SetExpertMagicNumber(InpMagicNum);
   return(INIT_SUCCEEDED);
}

void OnTick() {
   if(pos.Select(_Symbol) && pos.Magic() == InpMagicNum) return;
   
   // Logic: Gold usually moves inverse to USDJPY (Yield proxy).
   // Divergence: If USDJPY goes UP (Strong Dollar), Gold should go DOWN.
   // Signal: If USDJPY makes a new High but Gold fails to make a new Low (Strength?), Buy.
   // Simplification for EA: Correlation Breakout.
   
   double goldClose = iClose(_Symbol, PERIOD_CURRENT, 0);
   double goldOpen  = iOpen(_Symbol, PERIOD_CURRENT, 0);
   
   double pairClose = iClose(InpCorrSymbol, PERIOD_CURRENT, 0);
   double pairOpen  = iOpen(InpCorrSymbol, PERIOD_CURRENT, 0);
   
   if(pairClose == 0) return; // Error with correlation symbol
   
   // Normal Correlation: JPY UP -> Gold DOWN
   // Trade the correlation:
   bool jpyUp = (pairClose > pairOpen);
   bool goldUp = (goldClose > goldOpen);
   
   // If UJ is crashing (Yields down), Buy Gold
   if(!jpyUp && pairClose < iLow(InpCorrSymbol, PERIOD_CURRENT, 1)) {
       OpenTrade(ORDER_TYPE_BUY);
   }
   
   // If UJ is rallying (Yields up), Sell Gold
   if(jpyUp && pairClose > iHigh(InpCorrSymbol, PERIOD_CURRENT, 1)) {
       OpenTrade(ORDER_TYPE_SELL);
   }
}

void OpenTrade(ENUM_ORDER_TYPE type) {
   double price = (type == ORDER_TYPE_BUY) ? SymbolInfoDouble(_Symbol, SYMBOL_ASK) : SymbolInfoDouble(_Symbol, SYMBOL_BID);
   double sl = (type == ORDER_TYPE_BUY) ? price - 500*_Point : price + 500*_Point;
   double tp = (type == ORDER_TYPE_BUY) ? price + 1000*_Point : price - 1000*_Point; 
   
   double bal = AccountInfoDouble(ACCOUNT_BALANCE);
   double dist = MathAbs(price - sl);
   double lot = NormalizeDouble((bal * InpRiskPercent / 100.0) / (dist / _Point * 1.0), 2); 
   if(lot < 0.01) lot = 0.01;
   
   trade.PositionOpen(_Symbol, type, lot, price, sl, tp, "Yield Corr");
}
